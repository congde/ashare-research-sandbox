# 教学沙箱可选配置 — 与 web3-trading 同名变量兼容。
# 推荐：先在本机 sibling 目录启动 web3-trading（python main.py），沙箱会自动代理其 API。

# 显式指定 web3-trading 根目录（默认 ../web3-trading）
# WEB3_TRADING_ROOT=D:/work/gitee/web3-trading

# 显式指定上游地址（默认从 web3-trading/.env 的 SERVER_HOST + SERVER_PORT 推导，如 http://127.0.0.1:1024）
# WEB3_TRADING_BASE_URL=http://127.0.0.1:1024

# auto=先连 web3-trading 上游，失败再直连/离线；always=仅上游；never=不连上游
WEB3_TRADING_UPSTREAM=auto

# 可选：显式指定 web3-trading 的 .env 路径
# WEB3_TRADING_ENV=D:/work/gitee/web3-trading/.env

# ValueScan Open API（web3-trading 未运行时，沙箱直连备用）
VS_OPEN_API_KEY=
VS_OPEN_SECRET_KEY=
VS_OPEN_API_BASE_URL=https://api.valuescan.io/api/open/v1

# DexScan DEX 数据
DEX_API_KEY=
DEX_BASE_URL=https://kcapi.dexscan.trade

# 公网数据源（无需密钥）
KUCOIN_PUBLIC_API_BASE=https://api.kucoin.com
FEAR_GREED_API=https://api.alternative.me/fng/
