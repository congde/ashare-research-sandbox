# 教学沙箱可选配置 — dashboard / 雷达 / 行情 API 已内置在 src/，默认无需外部服务。
# vendor/web3-trading 仅作对照，不单独启动。

# never=内置直连或离线样本（默认）；auto=可选代理外部实例；always=仅代理
WEB3_TRADING_UPSTREAM=never

# 仅在 WEB3_TRADING_UPSTREAM=auto|always 时需要：
# WEB3_TRADING_BASE_URL=http://127.0.0.1:10240

# 可选：从 sibling ../web3-trading/.env 复用同名 API 密钥（不用于推断上游地址）
# WEB3_TRADING_ENV=D:/work/gitee/web3-trading/.env

# ValueScan Open API（直连；未配置时使用 data/dashboard 离线样本）
VS_OPEN_API_KEY=
VS_OPEN_SECRET_KEY=
VS_OPEN_API_BASE_URL=https://api.valuescan.io/api/open/v1

# DexScan DEX 数据
DEX_API_KEY=
DEX_BASE_URL=https://kcapi.dexscan.trade

# 公网数据源（无需密钥）
# web3交易所公网行情 API 基址（环境变量名保留兼容）
KUCOIN_PUBLIC_API_BASE=https://api.kucoin.com
FEAR_GREED_API=https://api.alternative.me/fng/

# offline=默认，读 snapshots/ 或内置样本；auto=先公网后 fallback；live=仅公网
# 执行 py scripts/course.py snapshot 时会临时切到 auto
DASHBOARD_DATA_MODE=offline

# DeepSeek / OpenAI 兼容 LLM（/research LLM 信号分析）
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro
OPENAI_API_TIMEOUT=90
