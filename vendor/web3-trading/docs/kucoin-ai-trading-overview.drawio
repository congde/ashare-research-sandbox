        <mxCell id="reach" value="输出 · 触达与带流量&#xa;━━━━━━━━━━━━&#xa;SEO · PUSH · Feed 内容广场 · 广告投放 → 回流交易主站" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=12;spacingTop=8;fontSize=12" parent="1" vertex="1">
          <mxGeometry x="400" y="560" width="520" height="90" as="geometry" />
