        <mxCell id="biz" value="输出 · 业务赋能（产品内）&#xa;━━━━━━━━━━━━&#xa;• 交易机器人&#xa;• 跟单 / Copy&#xa;• 合约 Futures&#xa;• 现货 Spot&#xa;• 理财 Earn&#xa;• 钱包 Wallet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=12;spacingTop=8;fontSize=12" parent="1" vertex="1">
